generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Acesso (NFR-05) ----------

model User {
  id            String         @id @default(cuid())
  name          String
  login         String         @unique
  passwordHash  String
  active        Boolean        @default(true)
  roleId        String
  role          Role           @relation(fields: [roleId], references: [id])
  sales         Sale[]
  cashRegisters CashRegister[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("user")
}

// Permissões são strings do catálogo em @beverage/shared — papéis novos
// (Caixa, Estoquista, Financeiro) são criados por configuração, sem código.
model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions String[]
  system      Boolean  @default(false)
  users       User[]
  createdAt   DateTime @default(now())

  @@map("role")
}

// ---------- Produtos e estoque ----------

model Product {
  id             String          @id @default(cuid())
  sku            String          @unique
  ean            String?         @unique
  name           String
  unit           String          @default("un")
  purchasePrice  Decimal         @db.Decimal(10, 2)
  salePrice      Decimal         @db.Decimal(10, 2)
  currentStock   Int             @default(0)
  minimumStock   Int             @default(0)
  active         Boolean         @default(true)
  batches        ProductBatch[]
  saleItems      SaleItem[]
  stockMovements StockMovement[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([name])
  @@map("product")
}

// Lote/validade (FR-08) — consumo FEFO best-effort na venda.
model ProductBatch {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id])
  batch     String?
  expiresAt DateTime?
  quantity  Int
  createdAt DateTime  @default(now())

  @@index([productId, expiresAt])
  @@map("product_batch")
}

enum StockMovementType {
  ENTRY
  EXIT
}

enum StockMovementSource {
  PURCHASE
  SALE
  ADJUSTMENT
  CANCELLATION
}

model StockMovement {
  id        String              @id @default(cuid())
  productId String
  product   Product             @relation(fields: [productId], references: [id])
  type      StockMovementType
  source    StockMovementSource
  quantity  Int
  unitCost  Decimal?            @db.Decimal(10, 2)
  saleId    String?
  sale      Sale?               @relation(fields: [saleId], references: [id])
  note      String?
  createdAt DateTime            @default(now())

  @@index([productId, createdAt])
  @@map("stock_movement")
}

// ---------- Clientes (FR-25, LGPD) ----------

model Customer {
  id          String              @id @default(cuid())
  name        String
  contact     String?
  active      Boolean             @default(true)
  sales       Sale[]
  receivables AccountReceivable[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@map("customer")
}

// ---------- Vendas / PDV ----------

enum SaleStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  PIX
  CARD
  CREDIT
}

enum DiscountType {
  AMOUNT
  PERCENT
}

model Sale {
  id             String             @id @default(cuid())
  status         SaleStatus         @default(IN_PROGRESS)
  operatorId     String
  operator       User               @relation(fields: [operatorId], references: [id])
  customerId     String?
  customer       Customer?          @relation(fields: [customerId], references: [id])
  cashRegisterId String?
  cashRegister   CashRegister?      @relation(fields: [cashRegisterId], references: [id])
  subtotal       Decimal            @default(0) @db.Decimal(10, 2)
  discountType   DiscountType?
  discountValue  Decimal?           @db.Decimal(10, 2)
  total          Decimal            @default(0) @db.Decimal(10, 2)
  paymentMethod  PaymentMethod?
  amountPaid     Decimal?           @db.Decimal(10, 2)
  change         Decimal?           @db.Decimal(10, 2)
  withInvoice    Boolean            @default(false)
  openedAt       DateTime           @default(now())
  completedAt    DateTime?
  cancelledAt    DateTime?
  items          SaleItem[]
  stockMovements StockMovement[]
  cashMovements  CashMovement[]
  receivable     AccountReceivable?

  @@index([status, completedAt])
  @@map("sale")
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  // Preço e custo congelados no momento da venda (margem/CMV — FR-33/FR-39).
  unitPrice Decimal @db.Decimal(10, 2)
  unitCost  Decimal @db.Decimal(10, 2)

  @@unique([saleId, productId])
  @@map("sale_item")
}

// ---------- Caixa (FR-27, BR-06) ----------

enum CashRegisterStatus {
  OPEN
  CLOSED
}

model CashRegister {
  id              String             @id @default(cuid())
  operatorId      String
  operator        User               @relation(fields: [operatorId], references: [id])
  status          CashRegisterStatus @default(OPEN)
  openingBalance  Decimal            @db.Decimal(10, 2)
  expectedBalance Decimal?           @db.Decimal(10, 2)
  countedBalance  Decimal?           @db.Decimal(10, 2)
  difference      Decimal?           @db.Decimal(10, 2)
  note            String?
  openedAt        DateTime           @default(now())
  closedAt        DateTime?
  movements       CashMovement[]
  sales           Sale[]

  @@map("cash_register")
}

enum CashMovementType {
  INFLOW
  OUTFLOW
  PULL // sangria
  FLOAT // suprimento
}

// Fonte única do fluxo de caixa (FR-28/29). cashRegisterId nulo = lançamento
// manual fora do caixa (FR-35).
model CashMovement {
  id             String             @id @default(cuid())
  cashRegisterId String?
  cashRegister   CashRegister?      @relation(fields: [cashRegisterId], references: [id])
  type           CashMovementType
  amount         Decimal            @db.Decimal(10, 2)
  description    String
  paymentMethod  PaymentMethod?
  categoryId     String?
  category       FinancialCategory? @relation(fields: [categoryId], references: [id])
  saleId         String?
  sale           Sale?              @relation(fields: [saleId], references: [id])
  occurredAt     DateTime           @default(now())

  @@index([occurredAt])
  @@map("cash_movement")
}

// ---------- Contas a receber / pagar ----------

enum ReceivableStatus {
  OPEN
  RECEIVED
}

model AccountReceivable {
  id         String           @id @default(cuid())
  customerId String
  customer   Customer         @relation(fields: [customerId], references: [id])
  saleId     String?          @unique
  sale       Sale?            @relation(fields: [saleId], references: [id])
  amount     Decimal          @db.Decimal(10, 2)
  dueDate    DateTime?
  status     ReceivableStatus @default(OPEN)
  receivedAt DateTime?
  createdAt  DateTime         @default(now())

  @@index([customerId, status])
  @@map("account_receivable")
}

enum PayableStatus {
  OPEN
  PAID
}

model AccountPayable {
  id          String             @id @default(cuid())
  description String
  supplier    String?
  amount      Decimal            @db.Decimal(10, 2)
  dueDate     DateTime
  status      PayableStatus      @default(OPEN)
  paidAt      DateTime?
  categoryId  String?
  category    FinancialCategory? @relation(fields: [categoryId], references: [id])
  createdAt   DateTime           @default(now())

  @@index([status, dueDate])
  @@map("account_payable")
}

// ---------- Configuração (NFR-10) ----------

enum FinancialCategoryKind {
  INCOME
  EXPENSE
}

model FinancialCategory {
  id            String                @id @default(cuid())
  name          String                @unique
  kind          FinancialCategoryKind
  system        Boolean               @default(false)
  active        Boolean               @default(true)
  cashMovements CashMovement[]
  payables      AccountPayable[]

  @@map("financial_category")
}

// Chave/valor JSON — meta de receita, política de estoque etc.
model Setting {
  key   String @id
  value String

  @@map("setting")
}
